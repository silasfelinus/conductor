WORDPRESS_PORT=8080

WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=change-this-local-password
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=0

# Required: generate unique local values before starting WordPress.
# Example generator:
#   curl -s https://api.wordpress.org/secret-key/1.1/salt/
WORDPRESS_AUTH_KEY=replace-with-generated-auth-key
WORDPRESS_SECURE_AUTH_KEY=replace-with-generated-secure-auth-key
WORDPRESS_LOGGED_IN_KEY=replace-with-generated-logged-in-key
WORDPRESS_NONCE_KEY=replace-with-generated-nonce-key
WORDPRESS_AUTH_SALT=replace-with-generated-auth-salt
WORDPRESS_SECURE_AUTH_SALT=replace-with-generated-secure-auth-salt
WORDPRESS_LOGGED_IN_SALT=replace-with-generated-logged-in-salt
WORDPRESS_NONCE_SALT=replace-with-generated-nonce-salt
