# Humboldt Scoop Solutions — Stripe credentials
# Copy this file to ".env" (same folder) and fill in your keys, OR define
# these as constants in wp-config.php, OR set them as real server env vars.
# Order of precedence: wp-config constant > server env var > this .env file.
#
# Never commit your real .env to a public repo.

# Secret key (server-side). Test keys start with sk_test_, live with sk_live_.
HSS_STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Publishable key (safe for the browser).
HSS_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret from Stripe Dashboard > Developers > Webhooks.
# Starts with whsec_
HSS_STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx


# ── SMS notifications (optional) ───────────────────────────────────────────
# Customers must opt in (a checkbox in their portal). Texts are short visit
# updates ("on the way", "all done"). Choose ONE provider.
#
# IMPORTANT (US): to deliver to US phones you need a real number you control
# and A2P 10DLC / toll-free registration with the provider. Alphanumeric
# sender IDs are NOT delivered to US handsets.

# Provider: brevo or twilio. If blank, auto-detected from the keys below.
HSS_SMS_PROVIDER=brevo

# Sender shown to recipients. Use your registered number for US delivery.
HSS_SMS_SENDER=ScoopSol

# Option A — Brevo (pay-as-you-go SMS credits).
# If the Kind Brevo Mailer plugin is in API mode, its v3 key is reused
# automatically and you can LEAVE THIS BLANK. Set it only to override.
HSS_BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx

# Option B — Twilio
HSS_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
HSS_TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
HSS_TWILIO_FROM_NUMBER=+14155550100
